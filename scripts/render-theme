#!/usr/bin/env python3
from __future__ import annotations

from pathlib import Path
import tomllib


ROOT = Path(__file__).resolve().parents[1]
THEME = ROOT / "themes" / "current.toml"
HEADER_TOML = "# Generated by scripts/render-theme. Edit themes/current.toml instead.\n"
HEADER_LUA = "-- Generated by scripts/render-theme. Edit themes/current.toml instead.\n"


def load_theme() -> tuple[str, str, dict[str, str], dict[str, str]]:
    data = tomllib.loads(THEME.read_text())
    return data["name"], data["flavour"], data["palette"], data["semantic"]


def color(palette: dict[str, str], semantic: dict[str, str], name: str) -> str:
    return palette[semantic.get(name, name)]


def write(path: Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)


def style(**attrs: str | bool) -> str:
    parts = []
    for key, value in attrs.items():
        if isinstance(value, bool):
            rendered = "true" if value else "false"
        else:
            rendered = f'"{value}"'
        parts.append(f"{key} = {rendered}")
    return "{ " + ", ".join(parts) + " }"


def render_alacritty(theme: str, flavour: str, palette: dict[str, str], semantic: dict[str, str]) -> None:
    bg = color(palette, semantic, "background")
    fg = color(palette, semantic, "foreground")
    panel = color(palette, semantic, "panel")
    border = color(palette, semantic, "panel_border")
    selection = color(palette, semantic, "selection")

    content = f"""{HEADER_TOML}[terminal.shell]
program = "C:\\\\Windows\\\\System32\\\\wsl.exe"
args = ["--exec", "zsh", "-lic", "exec zellij attach --create main"]

[window.padding]
x = 2
y = 2

[font]
size = 12
normal = {{ family = "FiraCode Nerd Font Mono", style = "Regular" }}

[keyboard]
bindings = [
  {{ key = "F11", action = "ToggleFullscreen" }},
  {{ key = "Enter", mods = "Alt", action = "ReceiveChar" }},
]

[colors.primary]
background = "{bg}"
foreground = "{fg}"
dim_foreground = "{color(palette, semantic, "dim_foreground")}"
bright_foreground = "{fg}"

[colors.cursor]
text = "{bg}"
cursor = "{palette["rosewater"]}"

[colors.vi_mode_cursor]
text = "{bg}"
cursor = "{palette["lavender"]}"

[colors.search.matches]
foreground = "{bg}"
background = "{palette["subtext0"]}"

[colors.search.focused_match]
foreground = "{bg}"
background = "{palette["green"]}"

[colors.footer_bar]
foreground = "{fg}"
background = "{border}"

[colors.hints.start]
foreground = "{bg}"
background = "{palette["yellow"]}"

[colors.hints.end]
foreground = "{fg}"
background = "{border}"

[colors.selection]
text = "{fg}"
background = "{selection}"

[colors.normal]
black = "{border}"
red = "{palette["red"]}"
green = "{palette["green"]}"
yellow = "{palette["yellow"]}"
blue = "{palette["blue"]}"
magenta = "{palette["pink"]}"
cyan = "{palette["teal"]}"
white = "{palette["subtext1"]}"

[colors.bright]
black = "{palette["overlay0"]}"
red = "{palette["red"]}"
green = "{palette["green"]}"
yellow = "{palette["yellow"]}"
blue = "{palette["blue"]}"
magenta = "{palette["pink"]}"
cyan = "{palette["teal"]}"
white = "{palette["subtext0"]}"

[colors.dim]
black = "{palette["base"]}"
red = "{palette["red"]}"
green = "{palette["green"]}"
yellow = "{palette["yellow"]}"
blue = "{palette["blue"]}"
magenta = "{palette["pink"]}"
cyan = "{palette["teal"]}"
white = "{palette["subtext1"]}"
"""
    write(ROOT / "alacritty/.config/alacritty/alacritty.toml", content)


def render_nvim(theme: str, flavour: str, palette: dict[str, str], semantic: dict[str, str]) -> None:
    colorscheme = f"{theme}-{flavour}"
    content = f"""{HEADER_LUA}return {{
  {{
    "catppuccin/nvim",
    name = "catppuccin",
    lazy = false,
    priority = 1000,
    opts = {{
      flavour = "{flavour}",
      term_colors = true,
      custom_highlights = function(colors)
        return {{
          Normal = {{ bg = colors.{semantic["background"]} }},
          NormalNC = {{ bg = colors.{semantic["background"]} }},
          SignColumn = {{ bg = colors.{semantic["background"]} }},
          StatusLine = {{ bg = colors.{semantic["panel"]} }},
          WinSeparator = {{ fg = colors.overlay0 }},
          CursorLine = {{ bg = colors.{semantic["panel"]} }},
          ColorColumn = {{ bg = colors.{semantic["panel"]} }},
          Visual = {{ bg = colors.{semantic["selection"]} }},
          NormalFloat = {{ bg = colors.{semantic["panel"]} }},
          FloatBorder = {{ fg = colors.{semantic["accent"]}, bg = colors.{semantic["panel"]} }},
          Pmenu = {{ bg = colors.{semantic["panel"]} }},
          PmenuSel = {{ bg = colors.{semantic["selection"]}, fg = colors.{semantic["foreground"]} }},
        }}
      end,
    }},
  }},
  {{
    "LazyVim/LazyVim",
    opts = {{
      colorscheme = "{colorscheme}",
    }},
  }},
}}
"""
    write(ROOT / "nvim/.config/nvim/lua/plugins/colorscheme.lua", content)


def render_jjui(theme: str, flavour: str, palette: dict[str, str], semantic: dict[str, str]) -> None:
    theme_name = f"{theme}-{flavour}"
    bg = color(palette, semantic, "background")
    fg = color(palette, semantic, "foreground")
    panel = color(palette, semantic, "panel")
    border = color(palette, semantic, "panel_border")
    selection = color(palette, semantic, "selection")
    dim = color(palette, semantic, "dim_foreground")
    accent = color(palette, semantic, "accent")
    accent_alt = color(palette, semantic, "accent_alt")

    config = f"""{HEADER_TOML}[ui]
theme = "{theme_name}"
"""
    write(ROOT / "jjui/.config/jjui/config.toml", config)

    entries = {
        "text": style(fg=fg, bg=bg),
        "dimmed": style(fg=dim),
        "selected": style(fg=fg, bg=selection, bold=True),
        "border": style(fg=border),
        "title": style(fg=accent, bold=True),
        "shortcut": style(fg=color(palette, semantic, "info"), bold=True),
        "matched": style(fg=color(palette, semantic, "warning"), bold=True),
        "source_marker": style(fg=bg, bg=color(palette, semantic, "success"), bold=True),
        "target_marker": style(fg=bg, bg=accent_alt, bold=True),
        "status": style(fg=fg, bg=panel),
        "status title": style(fg=bg, bg=accent, bold=True),
        "status shortcut": style(fg=color(palette, semantic, "info"), bold=True),
        "status dimmed": style(fg=dim),
        "revset title": style(fg=accent, bold=True),
        "revset text": style(fg=fg, bold=True),
        "revset completion selected": style(fg=fg, bg=selection, bold=True),
        "revset completion matched": style(fg=color(palette, semantic, "warning"), bold=True),
        "revset completion dimmed": style(fg=dim),
        "revisions": style(fg=fg, bg=bg),
        "revisions selected": style(fg=fg, bg=selection, bold=True),
        "revisions dimmed": style(fg=dim),
        "oplog selected": style(fg=fg, bg=selection, bold=True),
        "evolog": style(fg=fg, bg=panel),
        "evolog selected": style(fg=fg, bg=selection, bold=True),
        "help": style(fg=fg, bg=panel),
        "help title": style(fg=accent, bold=True, underline=True),
        "help border": style(fg=border),
        "menu": style(fg=fg, bg=panel),
        "menu title": style(fg=accent, bold=True),
        "menu shortcut": style(fg=color(palette, semantic, "info"), bold=True),
        "menu dimmed": style(fg=dim),
        "menu border": style(fg=border),
        "menu selected": style(fg=fg, bg=selection, bold=True),
        "confirmation": style(fg=fg, bg=panel),
        "confirmation text": style(fg=fg),
        "confirmation selected": style(fg=fg, bg=selection, bold=True),
        "confirmation dimmed": style(fg=dim),
        "confirmation border": style(fg=color(palette, semantic, "warning")),
        "undo": style(fg=fg, bg=panel),
        "undo confirmation dimmed": style(fg=dim),
        "undo confirmation selected": style(fg=fg, bg=selection, bold=True),
        "preview": style(fg=fg, bg=bg),
        "preview border": style(fg=border),
    }
    theme_body = "\n".join(f'"{key}" = {value}' for key, value in entries.items())
    write(ROOT / f"jjui/.config/jjui/themes/{theme_name}.toml", HEADER_TOML + theme_body + "\n")


def main() -> None:
    theme, flavour, palette, semantic = load_theme()
    render_alacritty(theme, flavour, palette, semantic)
    render_nvim(theme, flavour, palette, semantic)
    render_jjui(theme, flavour, palette, semantic)


if __name__ == "__main__":
    main()
